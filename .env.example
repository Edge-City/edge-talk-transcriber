# Copy this file to `.env` and fill in YOUR values. `.env` is gitignored.
# No secrets live here — only resource identifiers for your own GCP/Drive.

# --- Google Drive ---
# Folder whose subfolders contain the talk videos (from the folder URL:
# drive.google.com/drive/folders/THIS_ID). Must be in a Shared Drive if a
# service account writes the transcripts (service accounts can't write My Drive).
DRIVE_ROOT_FOLDER_ID=

# Optional: existing folder to write transcripts into. Leave blank to have the
# tool create/reuse a subfolder named TRANSCRIPTS_FOLDER_NAME under the root.
TRANSCRIPTS_FOLDER_ID=
TRANSCRIPTS_FOLDER_NAME=Transcripts

# --- Google Cloud (only needed for the cloud cache + deploy) ---
GCP_PROJECT_ID=
GCS_BUCKET_NAME=
GCS_CACHE_KEY=pipeline-state/transcriber-cache.json

# --- Cloud Run deploy (used by deploy.sh) ---
# NOTE: quote any value containing spaces (deploy.sh sources this file in bash).
REGION=us-central1
JOB_NAME=edge-talk-transcriber
AR_REPO=edge-talk-transcriber
# The service account the Cloud Run job runs as (must be a Content manager on
# the Shared Drive). Leave blank to set it on the gcloud command yourself.
RUNTIME_SA=
SCHEDULE="0 3 * * *"
TIMEZONE=America/New_York

# --- Transcription engine (faster-whisper) ---
WHISPER_MODEL=large-v3-turbo
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
# Leave blank to auto-detect language; set e.g. en to force English.
WHISPER_LANGUAGE=
WHISPER_BEAM_SIZE=5

# --- Inventory ---
# Comma-separated folder-name substrings to skip (your output folder is skipped
# by default so the tool never re-scans its own transcripts).
SKIP_FOLDERS=transcripts

# --- Runtime ---
# Scratch dir for downloads + audio. Blank = system temp (/tmp). On Cloud Run,
# point at a mounted disk/bucket if your videos are larger than the job memory.
WORKDIR=
